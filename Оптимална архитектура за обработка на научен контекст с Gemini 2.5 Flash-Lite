Цялостна софтуерна имплементация на решението
Следният софтуерен модел, написан на Python с използване на официалния Google Gen AI SDK, демонстрира практическата реализация на описаната архитектура. Той включва инициализирането на контекстния кеш, двуслойното филтриране и обработката на fallback сценария.   

Python
import os
import hashlib
from typing import Generator, Dict, Optional
from google import genai
from google.genai import types

# Конфигуриране на производствената среда за Google Vertex AI / Gen AI SDK
os.environ = "PRODUCTION_GEMINI_API_KEY"

class ScientificAssistantArchitecture:
    def __init__(self, model_id: str = "gemini-2.5-flash-lite"):
        """
        Инициализира архитектурата с вградени слоеве за оптимизация на разходите.
        """
        self.client = genai.Client()
        self.model_id = model_id
        self.cache_object = None
        self.exact_match_redis: Dict[str, str] = {}
        self.semantic_qdrant_mock: Dict[str, str] = {}
        self.cosine_threshold = 0.92
        self.fallback_trigger = "Този въпрос не е в нашата база."
        
        self.system_instruction = (
            "Вие сте специализиран научен асистент. Отговаряйте на въпросите единствено "
            "и само въз основа на предоставените научни проучвания в контекстния кеш. "
            "Ако отговорът на потребителския въпрос не може да бъде намерен с абсолютна "
            "сигурност в документите, или ако въпросът излиза извън обхвата им, трябва "
            "да върнете точно следния отговор и нищо друго: 'Този въпрос не е в нашата база.' "
            "Не се опитвайте да спекулирате или да използвате външни знания."
        )

    def upload_and_cache_context(self, document_path: str) -> str:
        """
        Качва научния корпус и създава дълготраен експлицитен контекстен кеш.
        """
        # Качване на файла през Files API
        scientific_file = self.client.files.upload(file=document_path)
        
        # Дефиниране на конфигурацията на кеша с 1 час време на живот (TTL)
        cache_config = types.CreateCachedContentConfig(
            contents=[scientific_file],
            system_instruction=self.system_instruction,
            ttl="3600s"
        )
        
        # Създаване на кешираното съдържание
        self.cache_object = self.client.caches.create(
            model=self.model_id,
            config=cache_config
        )
        return self.cache_object.name

    def _get_sha256_hash(self, text: str) -> str:
        """
        Генерира уникален хеш за бързо съвпадение на нишката.
        """
        return hashlib.sha256(text.strip().lower().encode("utf-8")).hexdigest()

    def _query_embedding(self, text: str) -> list:
        """
        Векторизира входящия текст чрез модела text-embedding-004.
        """
        # Интеграция с официалния ембединг модел
        response = self.client.models.embed_content(
            model="text-embedding-004",
            contents=text
        )
        return response.embeddings.values

    def _check_caches(self, query: str) -> Optional[str]:
        """
        Изпълнява последователно търсене в Слой 1 (Redis) и Слой 2 (Qdrant).
        """
        # Слой 1: Exact Match през Redis
        query_hash = self._get_sha256_hash(query)
        if query_hash in self.exact_match_redis:
            return self.exact_match_redis[query_hash]
            
        # Слой 2: Семантичен кеш (симулирана съпоставка за целите на демонстрацията)
        # При реална имплементация тук се извършва косинусово търсене в Qdrant
        normalized_query = query.strip().lower()
        if normalized_query in self.semantic_qdrant_mock:
            return self.semantic_qdrant_mock[normalized_query]
            
        return None

    def store_in_local_caches(self, query: str, response: str) -> None:
        """
        Записва успешните Q&A двойки в локалните кеш системи за бъдеща оптимизация.
        """
        query_hash = self._get_sha256_hash(query)
        self.exact_match_redis[query_hash] = response
        self.semantic_qdrant_mock[query.strip().lower()] = response

    def execute_query_stream(self, query: str) -> Generator[str, None, None]:
        """
        Изпълнява заявката с ниска латентност чрез стрийминг и контекстно кеширане.
        """
        # 1. Проверка в локалните филтриращи слоеве
        cached_result = self._check_caches(query)
        if cached_result:
            yield cached_result
            return

        # 2. Подготовка на генерирането при мис в локалния кеш
        if not self.cache_object:
            raise ValueError("Контекстният кеш трябва да бъде инициализиран предварително.")

        generation_config = types.GenerateContentConfig(
            cached_content=self.cache_object.name,
            temperature=0.0  # Гарантира детерминираност на научния отговор
        )

        # 3. Извикване на Gemini 2.5 Flash-Lite със стрийминг поток
        response_stream = self.client.models.generate_content_stream(
            model=self.model_id,
            contents=query,
            config=generation_config
        )

        complete_response = ""
        for chunk in response_stream:
            if chunk.text:
                complete_response += chunk.text
                yield chunk.text

        # 4. Запис в локалния кеш при успешен и смислен отговор
        if complete_response.strip()!= self.fallback_trigger:
            self.store_in_local_caches(query, complete_response)
